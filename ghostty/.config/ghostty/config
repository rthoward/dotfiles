scrollback-limit = 10000000

font-family = JetBrains Mono Medium
theme = light:Zenbones Light,dark:Zenbones Dark
font-size = 18

keybind = cmd+r=reload_config

keybind = ctrl+a>,=new_split:right
keybind = cmd+,=new_split:right
keybind = ctrl+a>.=new_split:down
keybind = cmd+.=new_split:down
keybind = shift+enter=text:\n
keybind = ctrl+a>r=prompt_tab_title

config-file = ?auto/theme.ghostty
